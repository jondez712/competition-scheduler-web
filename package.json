{
  "name": "competition-scheduler-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deploy:netlify": "npx --yes netlify-cli deploy --prod",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "build:lambda": "esbuild src/lambda/scheduleAssistantHandler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/lambda/scheduleAssistantHandler.js --alias:@=./src",
    "zip:lambda": "npm run build:lambda && rm -f dist/lambda/scheduleAssistantHandler.zip && cd dist/lambda && zip -q scheduleAssistantHandler.zip scheduleAssistantHandler.js",
    "benchmark": "vitest run src/lib/benchmark/benchmark.system.test.ts --reporter=verbose",
    "benchmark:ai": "AI_BENCHMARK=1 OPENAI_SCHEDULE_ASSISTANT_MODEL=gpt-4.1 vitest run src/lib/benchmark/benchmark.behavioral.test.ts src/lib/benchmark/benchmark.adversarial.test.ts --reporter=verbose",
    "benchmark:all": "vitest run src/lib/benchmark/ --reporter=verbose",
    "analyze:clusters": "node scripts/analyze-hitchkick-clusters.mjs"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "next": "16.2.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
