# Server-only (never NEXT_PUBLIC_*). For local dev: copy to .env.local and fill in values.
# On Netlify (or any host): set the same keys in Site configuration → Environment variables (never commit real URLs or keys here).

# Base URL without trailing slash — request becomes `${HITCHKICK_PROXY_BASE}/competition/{id}`
HITCHKICK_PROXY_BASE=

# Direct Hitchkick schedule base path (no /table suffix). Used with HITCHKICK_API_KEY; with PROXY_BASE set,
# schedule fetches race proxy vs direct so slow hops do not consume the whole serverless budget on large events.
HITCHKICK_DIRECT_BASE=
HITCHKICK_API_KEY=

# When set, GET /api/schedule returns raw Hitchkick JSON (can exceed host response limits on huge events).
# HITCHKICK_RETURN_FULL_SCHEDULE=1

# Netlify / large events: set to 1 to load only via direct Hitchkick (skips proxy + race). Use when the
# proxy returns 504 and you need the whole serverless duration for a multi‑MB JSON download.
# HITCHKICK_SCHEDULE_SKIP_PROXY=1

# Optional: AI draft schedule in staff panel (POST /api/schedule/build-draft).
# Default is heuristic-only; set both to try OpenAI first (still falls back to heuristic on failure).
# OPENAI_SCHEDULE_ENABLED=1
# OPENAI_API_KEY=
# OPENAI_SCHEDULE_MODEL=
# OPENAI_SCHEDULE_TEMPERATURE=

# Schedule assistant (sidebar): uses OPENAI_API_KEY. Optional model/temp/JSON-budget keys are built in
# src/lib/openaiAssistantEnvKeys.ts — add matching names in your host dashboard if you override defaults.

# Optional: POST base for publishing schedule table updates — `${HITCHKICK_PUBLISH_PROXY_BASE}/competition/{id}/table`
# When unset, POST /api/schedule/publish validates and returns a merged payload only (dry run).
# HITCHKICK_PUBLISH_PROXY_BASE=
