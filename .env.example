# Server-only (never NEXT_PUBLIC_*). For local dev: copy to .env.local.
# On Netlify (or any host): add the same variable names in the dashboard (Environment variables), then redeploy.

# Base URL without trailing slash — request becomes `${HITCHKICK_PROXY_BASE}/competition/{id}`
HITCHKICK_PROXY_BASE=https://auf2hpeud1.execute-api.us-east-2.amazonaws.com/dev/hitchkick-proxy

# Optional: direct Hitchkick API fallback when the proxy errors (502, timeout, etc.). Set the same
# key the macOS app uses for direct schedule requests (do not commit real keys).
HITCHKICK_DIRECT_BASE=https://hitchkick.com/api/external/event/schedule/competition
HITCHKICK_API_KEY=

# Optional: AI draft schedule in staff panel (POST /api/schedule/build-draft).
# Default is heuristic-only; set both to try OpenAI first (still falls back to heuristic on failure).
# OPENAI_SCHEDULE_ENABLED=1
# OPENAI_API_KEY=
# OPENAI_SCHEDULE_MODEL=gpt-4o
# Stronger (frontier, pricier): gpt-5.5
# Budget: gpt-4o-mini
# OPENAI_SCHEDULE_TEMPERATURE=0.15
#
# Schedule assistant (sidebar): uses OPENAI_API_KEY. Defaults to gpt-4o-mini if unset (independent of OPENAI_SCHEDULE_MODEL).
# OPENAI_SCHEDULE_ASSISTANT_MODEL=gpt-4o-mini
# Temperature is omitted for GPT-5 / o-series models (API only supports default); optional for others:
# OPENAI_SCHEDULE_ASSISTANT_TEMPERATURE=0.3
# If OpenAI returns context_length_exceeded, lower pruned JSON size (default 55000 chars, min 10000).
# OPENAI_SCHEDULE_ASSISTANT_MAX_JSON_CHARS=120000

# Optional: POST base for publishing schedule table updates — `${HITCHKICK_PUBLISH_PROXY_BASE}/competition/{id}/table`
# When unset, POST /api/schedule/publish validates and returns a merged payload only (dry run).
# HITCHKICK_PUBLISH_PROXY_BASE=
